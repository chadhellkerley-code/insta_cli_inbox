<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Cuentas - Insta Cli Inbox</title>
  <link rel="stylesheet" href="/styles.css" />
  <style>
    .accounts-shell {
      display: grid;
      gap: 1.5rem;
    }

    .accounts-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 1.5rem;
      align-items: start;
    }

    .panel {
      border: 1px solid var(--border-color);
      border-radius: 10px;
      padding: 1.25rem;
      background: linear-gradient(180deg, #ffffff 0%, #f7faff 100%);
      box-shadow: 0 10px 24px rgba(0, 0, 0, 0.04);
    }

    .panel-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .panel-header h2,
    .panel-header h3 {
      margin-bottom: 0;
    }

    .panel-note {
      margin: 0;
      color: #5d6b82;
      font-size: 0.95rem;
    }

    .panel-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      align-items: center;
    }

    .import-form {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      align-items: center;
    }

    .import-form input[type="file"] {
      flex: 1 1 240px;
      border: 1px dashed var(--border-color);
      padding: 0.75rem;
      border-radius: 8px;
      background: #fff;
    }

    .btn,
    .btn-secondary,
    .btn-danger,
    .btn-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.35rem;
      padding: 0.55rem 0.9rem;
      border-radius: 8px;
      border: none;
      cursor: pointer;
      text-decoration: none;
      font-size: 0.95rem;
      font-family: inherit;
    }

    .btn {
      background: var(--primary-color);
      color: #fff;
    }

    .btn:hover {
      background: var(--primary-dark);
    }

    .btn-secondary {
      background: #e8eef8;
      color: #244268;
    }

    .btn-secondary:hover {
      background: #d9e5f5;
    }

    .btn-danger {
      background: #fce8e8;
      color: #a73535;
    }

    .btn-danger:hover {
      background: #f7d7d7;
    }

    .btn-link {
      background: transparent;
      color: var(--primary-dark);
      padding-left: 0;
      padding-right: 0;
    }

    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.35rem 0.7rem;
      border-radius: 999px;
      font-size: 0.85rem;
      font-weight: 600;
      white-space: nowrap;
    }

    .status-badge.session-on {
      background: #dcf7e4;
      color: #14773e;
    }

    .status-badge.session-off {
      background: #edf1f5;
      color: #67768a;
    }

    .table-wrap {
      overflow-x: auto;
    }

    .accounts-table {
      min-width: 780px;
    }

    .accounts-table td {
      vertical-align: middle;
    }

    .actions-cell {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .helper-text {
      margin-top: 0.45rem;
      color: #6a7587;
      font-size: 0.9rem;
    }

    .muted {
      color: #6a7587;
    }

    .import-result {
      display: none;
      margin-top: 1rem;
      padding: 0.85rem 1rem;
      border-radius: 8px;
      border: 1px solid transparent;
    }

    .import-result.is-visible {
      display: block;
    }

    .import-result.success {
      background: #edf9f1;
      border-color: #bde2c7;
      color: #1d6b3a;
    }

    .import-result.error {
      background: #fff1f1;
      border-color: #efc4c4;
      color: #a33a3a;
    }

    .alert-success {
      background: #edf9f1;
      color: #1d6b3a;
      border: 1px solid #bde2c7;
    }

    .alert-warning {
      background: #fff6e6;
      color: #8a5a00;
      border: 1px solid #f2d59c;
    }

    .import-errors {
      margin: 0.75rem 0 0;
      padding-left: 1.2rem;
    }

    .form-card {
      display: grid;
      gap: 1rem;
    }

    .field-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1rem;
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }

    .field input {
      padding: 0.65rem 0.75rem;
      border: 1px solid var(--border-color);
      border-radius: 8px;
      background: #fff;
    }

    .field input[disabled] {
      background: #f2f5f8;
      color: #67768a;
    }

    .form-footer {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      align-items: center;
    }

    @media (max-width: 768px) {
      .panel {
        padding: 1rem;
      }

      .accounts-table {
        min-width: 680px;
      }
    }
  </style>
</head>
<body>
  <header class="navbar">
    <div class="logo">Insta Cli Inbox</div>
    <nav>
      <a href="/dashboard">Dashboard</a>
      <a href="/accounts" class="active">Cuentas</a>
      <a href="/config">Configuración</a>
      <a href="/inbox">Inbox</a>
      <a href="/metrics">Métricas</a>
      <a href="/logout">Salir</a>
    </nav>
    <div class="user-info"><%= user.email %> (<%= user.role %>)</div>
  </header>

  <main class="container accounts-shell">
    <section class="panel">
      <div class="panel-header">
        <div>
          <h1>Cuentas de Instagram</h1>
          <p class="panel-note">Gestiona accesos, sesiones y proxies de todas tus cuentas desde un solo lugar.</p>
        </div>
      </div>

      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <% if (warning) { %>
        <div class="alert alert-warning"><%= warning %></div>
      <% } %>

      <% if (success) { %>
        <div class="alert alert-success"><%= success %></div>
      <% } %>

      <div class="panel-actions">
        <span class="muted"><strong><%= accounts.length %></strong> cuenta(s) registradas</span>
        <a href="/accounts/csv-template" class="btn-link">Descargar ejemplo CSV</a>
      </div>
    </section>

    <section class="panel">
      <div class="panel-header">
        <div>
          <h2>Importar cuentas por CSV</h2>
          <p class="panel-note">Formato soportado: <code>username,password,secret_2fa,proxy_host,proxy_port,proxy_username,proxy_password</code>.</p>
        </div>
      </div>

      <form id="csv-import-form" class="import-form" action="/accounts/import-csv" method="post" enctype="multipart/form-data">
        <input type="file" name="csv_file" id="csv_file" accept=".csv,text/csv" required />
        <button type="submit" class="btn">Importar CSV</button>
      </form>
      <p class="helper-text">Si <code>proxy_host</code> está vacío, se usará proxy local. Puedes subir CSV con o sin encabezado.</p>
      <div id="csv-import-result" class="import-result" aria-live="polite"></div>
    </section>

    <% if (editingAccount) { %>
      <section class="panel">
        <div class="panel-header">
          <div>
            <h2>Editar cuenta</h2>
            <p class="panel-note">Puedes actualizar contraseña, 2FA y proxy sin modificar el usuario.</p>
          </div>
          <a href="/accounts" class="btn-secondary">Cancelar edición</a>
        </div>

        <form action="/accounts/edit/<%= editingAccount.id %>" method="post" class="form-card">
          <div class="field-grid">
            <div class="field">
              <label for="edit_username">Usuario</label>
              <input type="text" id="edit_username" value="<%= editingAccount.username %>" disabled />
            </div>

            <div class="field">
              <label for="edit_password">Contraseña</label>
              <input type="password" id="edit_password" name="password" value="<%= editingAccount.password || '' %>" required />
            </div>

            <div class="field">
              <label for="edit_secret_2fa">Secreto 2FA</label>
              <input type="text" id="edit_secret_2fa" name="secret_2fa" value="<%= editingAccount.twofactor || '' %>" />
            </div>

            <div class="field">
              <label for="edit_proxy_host">Host proxy</label>
              <input type="text" id="edit_proxy_host" name="proxy_host" value="<%= editingAccount.proxy_host || '' %>" />
            </div>

            <div class="field">
              <label for="edit_proxy_port">Puerto proxy</label>
              <input type="number" id="edit_proxy_port" name="proxy_port" value="<%= editingAccount.proxy_port || '' %>" min="1" />
            </div>

            <div class="field">
              <label for="edit_proxy_username">Usuario proxy</label>
              <input type="text" id="edit_proxy_username" name="proxy_username" value="<%= editingAccount.proxy_username || '' %>" />
            </div>

            <div class="field">
              <label for="edit_proxy_password">Contraseña proxy</label>
              <input type="password" id="edit_proxy_password" name="proxy_password" value="<%= editingAccount.proxy_password || '' %>" />
            </div>
          </div>

          <div class="form-footer">
            <button type="submit" class="btn">Guardar cambios</button>
            <a href="/accounts" class="btn-secondary">Volver al listado</a>
          </div>
        </form>
      </section>
    <% } %>

    <section class="accounts-grid">
      <section class="panel">
        <div class="panel-header">
          <div>
            <h2>Agregar cuenta manualmente</h2>
            <p class="panel-note">Usa este formulario cuando quieras cargar una cuenta individual.</p>
          </div>
        </div>

        <form action="/accounts/add" method="post" class="form-card">
          <div class="field-grid">
            <div class="field">
              <label for="username">Usuario</label>
              <input type="text" id="username" name="username" required />
            </div>

            <div class="field">
              <label for="password">Contraseña</label>
              <input type="password" id="password" name="password" required />
            </div>

            <div class="field">
              <label for="secret_2fa">Secreto 2FA</label>
              <input type="text" id="secret_2fa" name="secret_2fa" />
            </div>

            <div class="field">
              <label for="proxy_host">Host proxy</label>
              <input type="text" id="proxy_host" name="proxy_host" />
            </div>

            <div class="field">
              <label for="proxy_port">Puerto proxy</label>
              <input type="number" id="proxy_port" name="proxy_port" min="1" />
            </div>

            <div class="field">
              <label for="proxy_username">Usuario proxy</label>
              <input type="text" id="proxy_username" name="proxy_username" />
            </div>

            <div class="field">
              <label for="proxy_password">Contraseña proxy</label>
              <input type="password" id="proxy_password" name="proxy_password" />
            </div>
          </div>

          <div class="form-footer">
            <button type="submit" class="btn">Guardar cuenta</button>
          </div>
        </form>
      </section>

      <section class="panel">
        <div class="panel-header">
          <div>
            <h2>Resumen rápido</h2>
            <p class="panel-note">Consulta el estado de sesión y la configuración de proxy antes de operar con cada cuenta.</p>
          </div>
        </div>

        <p class="helper-text">Las cuentas con estado <strong>Con sesión</strong> ya tienen una sesión serializada guardada en SQLite.</p>
        <p class="helper-text">Si una cuenta no tiene <code>proxy_host</code>, la app usará el proxy local configurado para el entorno.</p>
      </section>
    </section>

    <section class="panel">
      <div class="panel-header">
        <div>
          <h2>Cuentas guardadas</h2>
          <p class="panel-note">Edita credenciales, elimina cuentas obsoletas o inicia sesión en Instagram cuando lo necesites.</p>
        </div>
      </div>

      <% if (accounts && accounts.length > 0) { %>
        <div class="table-wrap">
          <table class="accounts-table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Usuario</th>
                <th>Estado</th>
                <th>Proxy</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% accounts.forEach(function(acc) { %>
                <tr>
                  <td><%= acc.id %></td>
                  <td><strong><%= acc.username %></strong></td>
                  <td>
                    <% if (acc.has_session) { %>
                      <span class="status-badge session-on">Con sesión</span>
                    <% } else { %>
                      <span class="status-badge session-off">Sin sesión</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (acc.proxy_host) { %>
                      <%= acc.proxy_host %><%= acc.proxy_port ? ':' + acc.proxy_port : '' %>
                    <% } else { %>
                      <span class="muted">Proxy local</span>
                    <% } %>
                  </td>
                  <td class="actions-cell">
                    <a href="/accounts/login/<%= acc.id %>" class="btn">Iniciar sesión</a>
                    <a href="/accounts/edit/<%= acc.id %>" class="btn-secondary">Editar</a>
                    <button
                      type="button"
                      class="btn-danger js-delete-account"
                      data-account-id="<%= acc.id %>"
                      data-account-username="<%= acc.username %>"
                    >
                      Eliminar
                    </button>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p>No hay cuentas guardadas todavía.</p>
      <% } %>
    </section>
  </main>

  <script>
    (function () {
      const importForm = document.getElementById('csv-import-form');
      const importResult = document.getElementById('csv-import-result');

      function escapeHtml(value) {
        return String(value)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }

      function renderImportResult(payload, isError) {
        const imported = payload && typeof payload.imported === 'number' ? payload.imported : 0;
        const skipped = payload && typeof payload.skipped === 'number' ? payload.skipped : 0;
        const errors = payload && Array.isArray(payload.errors) ? payload.errors : [];

        importResult.className = 'import-result is-visible ' + (isError ? 'error' : 'success');

        let html = '<strong>' + imported + ' cuentas importadas, ' + skipped + ' omitidas.</strong>';

        if (errors.length > 0) {
          html += '<ul class="import-errors">' + errors.map(function (message) {
            return '<li>' + escapeHtml(message) + '</li>';
          }).join('') + '</ul>';
        }

        importResult.innerHTML = html;
      }

      if (importForm) {
        importForm.addEventListener('submit', async function (event) {
          event.preventDefault();

          const formData = new FormData(importForm);

          try {
            const response = await fetch(importForm.action, {
              method: 'POST',
              body: formData,
            });

            const payload = await response.json();
            renderImportResult(payload, !response.ok || (payload.errors && payload.errors.length > 0 && payload.imported === 0));

            if (response.ok && payload.imported > 0) {
              importForm.reset();
              setTimeout(function () {
                window.location.reload();
              }, 900);
            }
          } catch (error) {
            renderImportResult({
              imported: 0,
              skipped: 0,
              errors: ['No se pudo importar el archivo CSV.'],
            }, true);
          }
        });
      }

      document.querySelectorAll('.js-delete-account').forEach(function (button) {
        button.addEventListener('click', async function () {
          const accountId = button.getAttribute('data-account-id');
          const username = button.getAttribute('data-account-username');
          const confirmed = window.confirm('¿Seguro que quieres eliminar la cuenta "' + username + '"?');

          if (!confirmed) {
            return;
          }

          try {
            const response = await fetch('/accounts/' + accountId, {
              method: 'DELETE',
            });

            if (!response.ok) {
              throw new Error('No se pudo eliminar la cuenta.');
            }

            window.location.href = '/accounts';
          } catch (error) {
            window.alert('No se pudo eliminar la cuenta.');
          }
        });
      });
    }());
  </script>
</body>
</html>
