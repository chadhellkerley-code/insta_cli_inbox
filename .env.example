SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Next.js app in web/
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-side Supabase credentials
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# 32-byte AES key for encrypted automation AI credentials.
# Use 64 hex chars, 32 raw chars, or base64 that decodes to 32 bytes.
AI_CREDENTIALS_ENCRYPTION_KEY=change-this-32-byte-key-material

# Session secret
SESSION_SECRET=change-this-session-secret

# Meta OAuth for the Next.js app in web/ using Instagram API with Instagram Login
META_APP_ID=your-instagram-app-id
META_APP_SECRET=your-instagram-app-secret
META_WEBHOOK_VERIFY_TOKEN=meta_inbox_state_secret_2023
META_OAUTH_REDIRECT_URI=https://insta-cli-inbox.vercel.app/auth/callback
NEXT_PUBLIC_META_APP_ID=your-instagram-app-id
META_OAUTH_STATE_SECRET=change-this-meta-oauth-state-secret

# Calendly OAuth
CALENDLY_CLIENT_ID=your-calendly-client-id
CALENDLY_CLIENT_SECRET=your-calendly-client-secret
CALENDLY_OAUTH_REDIRECT_URI=https://insta-cli-inbox.vercel.app/api/calendly/oauth/callback
CALENDLY_OAUTH_SCOPES=users:read event_types:read
CALENDLY_OAUTH_STATE_SECRET=change-this-calendly-oauth-state-secret
