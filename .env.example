SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# App web Next.js/Vercel. Si queres, usa exactamente los mismos valores que arriba.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Claves de servicio para operaciones de servidor.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# Secreto para las cookies de sesión
SESSION_SECRET=change-this-session-secret

# Repositorio de GitHub con las actualizaciones del exe (formato owner/repo)
GITHUB_REPO=usuario/insta-cli-inbox-exe

# Puerto en el que se ejecutará el servidor (opcional, por defecto 3000)
#PORT=3000
